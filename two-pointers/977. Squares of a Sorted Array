class Solution:
    def sortedSquares(self, nums: List[int]) -> List[int]:
        pos = []
        neg = []

        for num in nums:
            if num >= 0:
                pos.append(num)
            else :
                neg.append(num)

        if len(neg) == 0:
            return [x*x for x in pos]

        if len(pos) == 0:
            res = [x*x for x in neg]
            res.reverse()
            return res
        
        neg = [x*x for x in neg][::-1]
        pos = [x*x for x in pos]

        i = 0
        j = 0
        result = []
        
        while i < len(pos) and j < len(neg):
            if pos[i] < neg[j]:
                result.append(pos[i])
                i += 1
            else:
                result.append(neg[j])
                j += 1
        
        while i < len(pos):
            result.append(pos[i])
            i += 1

        while j < len(neg):
            result.append(neg[j])
            j += 1

        return result

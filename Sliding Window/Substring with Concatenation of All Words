class Solution:
    def findSubstring(self, s: str, words: List[str]) -> List[int]:
        if not s or not words:
            return []
        word_len = len(words[0])
        window_len = word_len * len(words)

        target = {}
        for i in words:
            target[i] = target.get(i,0) + 1

        result = []

        for offset in range(word_len):
            low = offset
            window = {}

            for high in range(offset,len(s) - word_len + 1, word_len):
                word = s[high:high+word_len]
                if word in target:
                    window[word] = window.get(word,0) + 1

                    while window[word] > target[word]:
                        left_word = s[low:low + word_len]
                        window[left_word] -= 1
                        if window[left_word] == 0:
                            del window[left_word]
                        low += word_len
                    if high - low + word_len == window_len:
                        result.append(low)
                       
                else:
                    window.clear()
                    low = high + word_len
        return result


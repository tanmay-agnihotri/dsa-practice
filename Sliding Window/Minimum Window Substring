Code
class Solution:
    def minWindow(self, s: str, t: str) -> str:
        if not s or not t:
            return ""
        target_freq = {}
        for ch in t:
            target_freq[ch] = target_freq.get(ch , 0) + 1
        
        window_freq = {}
        required = len(target_freq)
        formed = 0
        low = 0
        min_length = float('inf')
        result = ""

        for high in range(len(s)):
            window_freq[s[high]] = window_freq.get(s[high], 0) + 1
            if s[high] in target_freq and target_freq[s[high]] == window_freq[s[high]]:
                formed += 1

                while formed == required:
                    window_size = high - low + 1
                    if window_size < min_length:
                        min_length = window_size
                        result = s[low:high + 1]

                    window_freq[s[low]] -= 1
                    if s[low] in target_freq and target_freq[s[low]] > window_freq[s[low]]:
                        formed -= 1
                    low += 1
        return result

